<ui:ToolWindowView x:Class="WinDbgBridge.BridgeToolWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:ui="clr-namespace:DbgX.Interfaces.UI;assembly=DbgX.Interfaces"
                   ui:ToolWindowView.TabTitle="WinDbg Bridge"
                   mc:Ignorable="d"
                   d:DesignHeight="420"
                   d:DesignWidth="520">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="WinDbg Bridge" />
            <TextBlock Margin="0,4,0,0" Text="{Binding StatusText}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock FontWeight="SemiBold" Text="Named pipe" />
            <TextBox Margin="0,6,0,0"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     Text="{Binding PipePath, Mode=OneWay}" />
            <TextBlock Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Text="{Binding PromptText}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,16,0,0" Orientation="Horizontal">
            <Button MinWidth="110"
                    Padding="12,4"
                    Command="{Binding StartBridgeCommand}"
                    Content="Start bridge" />
            <Button MinWidth="110"
                    Margin="8,0,0,0"
                    Padding="12,4"
                    Command="{Binding CopyPromptCommand}"
                    Content="Copy prompt" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock FontWeight="SemiBold" Text="Recent activity" />
            <ListBox Margin="0,6,0,0"
                     x:Name="ActivityLogListBox"
                      FontFamily="Consolas"
                     SelectionMode="Extended"
                     PreviewKeyDown="ActivityLogListBox_OnPreviewKeyDown"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ItemsSource="{Binding LogEntries}" />
        </StackPanel>
    </Grid>
</ui:ToolWindowView>
